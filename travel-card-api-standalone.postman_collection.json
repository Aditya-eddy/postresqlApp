		{
			"name": "Wallet",
			"item": [
				{
					"name": "GET /account/wallet/check — random member",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var memberIds = ['19', '20', '21', '22', '23'];",
									"var randomId = memberIds[Math.floor(Math.random() * memberIds.length)];",
									"pm.variables.set('agodaMemberId', randomId);",
									"console.log('Using X-Agoda-Member-Id: ' + randomId);"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Agoda-Member-Id",
								"value": "{{agodaMemberId}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/account/wallet/check",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"account",
								"wallet",
								"check"
							]
						},
						"description": "Check wallet for a member. Pre-request script picks a random X-Agoda-Member-Id from [19, 20, 21, 22, 23] on each send, so you get different results each time."
					},
					"response": []
				}
			]
		},
